# Twilio (get these from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# Dashboard login password
DASHBOARD_PASSWORD=your_secure_password

# Session secret (use a long random string in production)
SESSION_SECRET=use_a_long_random_string_here

# Port is set by Railway automatically; only set locally if needed
# PORT=3000
